<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SQLdod - 数据库管理工具</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-container">
    <div class="login-header">
      <h1><span class="logo-icon">🗄️</span> SQLdod</h1>
      <p>数据库管理工具</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="connection-tabs">
      <button class="tab-btn active" onclick="switchTab('new')">新建连接</button>
      <button class="tab-btn" onclick="switchTab('saved')">已保存连接</button>
    </div>

    <!-- 新建连接表单 -->
    <div id="tab-new" class="tab-content active">
      <form id="connectionForm" class="connection-form">
        <div class="form-group">
          <label>数据库类型</label>
          <select id="dbType" name="type" class="form-control" onchange="handleTypeChange()">
            <option value="mysql">MySQL</option>
            <option value="postgresql">PostgreSQL</option>
            <option value="sqlite">SQLite</option>
          </select>
        </div>

        <div class="form-group">
          <label>连接名称</label>
          <input type="text" name="name" class="form-control" placeholder="可选，用于标识此连接">
        </div>

        <div id="serverFields">
          <div class="form-group">
            <label>主机</label>
            <input type="text" name="host" class="form-control" value="localhost" placeholder="localhost">
          </div>
          <div class="form-group">
            <label>端口</label>
            <input type="number" name="port" class="form-control" id="portInput" value="3306">
          </div>
          <div class="form-group">
            <label>用户名</label>
            <input type="text" name="user" class="form-control" id="userInput" placeholder="root">
          </div>
          <div class="form-group">
            <label>密码</label>
            <input type="password" name="password" class="form-control" placeholder="输入密码">
          </div>
          <div class="form-group">
            <label>数据库（可选）</label>
            <input type="text" name="database" class="form-control" placeholder="留空则连接后选择">
          </div>
        </div>

        <div id="sqliteFields" style="display:none;">
          <div class="form-group">
            <label>数据库文件路径</label>
            <input type="text" name="filePath" class="form-control" placeholder="例如: data/mydb.db（相对于项目目录）">
          </div>
        </div>

        <div class="form-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" name="savePassword" value="true" checked>
            <span>保存密码（用于快速连接）</span>
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="connectBtn">
          <span class="btn-text">连接数据库</span>
          <span class="btn-loading" style="display:none;">连接中...</span>
        </button>
      </form>
    </div>

    <!-- 已保存连接列表 -->
    <div id="tab-saved" class="tab-content">
      <div id="savedConnectionsList" class="saved-list">
        <p class="empty-text">加载中...</p>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    let currentTab = 'new';

    function switchTab(tab) {
      currentTab = tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector(`[onclick="switchTab('${tab}')"]`).classList.add('active');
      document.getElementById(`tab-${tab}`).classList.add('active');

      if (tab === 'saved') {
        loadSavedConnections();
      }
    }

    function handleTypeChange() {
      const type = document.getElementById('dbType').value;
      document.getElementById('serverFields').style.display = type === 'sqlite' ? 'none' : 'block';
      document.getElementById('sqliteFields').style.display = type === 'sqlite' ? 'block' : 'none';

      if (type === 'mysql') {
        document.getElementById('portInput').value = '3306';
        document.getElementById('userInput').placeholder = 'root';
      } else if (type === 'postgresql') {
        document.getElementById('portInput').value = '5432';
        document.getElementById('userInput').placeholder = 'postgres';
      }
    }

    async function loadSavedConnections() {
      try {
        const resp = await fetch('/saved-connections');
        const connections = await resp.json();
        const list = document.getElementById('savedConnectionsList');

        if (!connections || connections.length === 0) {
          list.innerHTML = '<p class="empty-text">暂无保存的连接</p>';
          return;
        }

        list.innerHTML = connections.map(c => `
          <div class="saved-item">
            <div class="saved-info">
              <strong>${c.name || c.host || 'SQLite'}</strong>
              <span class="saved-detail">${c.type.toUpperCase()} | ${c.host || 'SQLite'}${c.database ? ' / ' + c.database : ''}</span>
            </div>
            <div class="saved-actions">
              <button class="btn btn-sm btn-primary" onclick="quickConnect('${c.id}')">连接</button>
              <button class="btn btn-sm btn-danger" onclick="deleteConnection('${c.id}')">删除</button>
            </div>
          </div>
        `).join('');
      } catch (err) {
        document.getElementById('savedConnectionsList').innerHTML = '<p class="empty-text">加载失败</p>';
      }
    }

    async function quickConnect(id) {
      try {
        const resp = await fetch('/connection/quick-connect', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const result = await resp.json();
        if (result.success) {
          window.location.href = '/workspace';
        } else {
          alert('连接失败: ' + result.error);
        }
      } catch (err) {
        alert('连接失败: ' + err.message);
      }
    }

    async function deleteConnection(id) {
      if (!confirm('确定删除此连接配置吗？')) return;
      try {
        await fetch('/delete-connection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        loadSavedConnections();
      } catch (err) {
        alert('删除失败');
      }
    }

    document.getElementById('connectionForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      const btn = document.getElementById('connectBtn');
      btn.querySelector('.btn-text').style.display = 'none';
      btn.querySelector('.btn-loading').style.display = 'inline';
      btn.disabled = true;

      try {
        const resp = await fetch('/connection/connect', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await resp.json();
        if (result.success) {
          window.location.href = '/workspace';
        } else {
          alert('连接失败: ' + result.error);
        }
      } catch (err) {
        alert('连接失败: ' + err.message);
      } finally {
        btn.querySelector('.btn-text').style.display = 'inline';
        btn.querySelector('.btn-loading').style.display = 'none';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
